# GeniXCMS Go API Service Configuration

# Database Driver: mysql, postgres, sqlite3
DB_DRIVER=mysql

# MySQL / PostgreSQL Settings
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=genixcms
DB_USER=root
DB_PASS=

# SQLite Settings (only if DB_DRIVER=sqlite3)
DB_FILE=e:/laragon/www/genixcms2/inc/db/genixcms.db

# Server
PORT=8080
GIN_MODE=release

# Internal security secret (must match go_service_secret in GeniXCMS Options)
GX_SECRET=change-me-to-a-random-secret-string
