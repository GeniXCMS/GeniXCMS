<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>{Site::$name} - {Site::$desc}</title>
    <!-- Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <!-- Google Fonts -->
    <link href="{Themusk::getFontsLink()|noescape}" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script id="tailwind-config">
        var primary_color = {Themusk::opt('primary_color')};
        var on_primary_color = {Themusk::opt('on_primary_color')};
        var bg_surface = {Themusk::opt('bg_surface')};
        var on_surface = {Themusk::opt('on_surface')};
        var on_surface_variant = {Themusk::opt('on_surface_variant')};
        
        var font_headline = {Themusk::opt('font_headline')};
        var font_body = {Themusk::opt('font_body')};

        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary-container": "#c7eade",
                        "on-primary-fixed-variant": "#426258",
                        "surface-container": "#ebeef3",
                        "tertiary": "#536447",
                        "surface-variant": "#dde3ea",
                        "on-error-container": "#752121",
                        "on-secondary-fixed": "#3d403e",
                        "secondary-fixed-dim": "#d2d5d2",
                        "on-primary-container": "#39584e",
                        "on-secondary": "#f7f9f7",
                        "primary": primary_color,
                        "inverse-on-surface": "#9c9d9f",
                        "tertiary-dim": "#47583c",
                        "error-dim": "#4e0309",
                        "secondary": "#5c605e",
                        "surface-container-lowest": "#ffffff",
                        "on-tertiary-fixed": "#3e4e33",
                        "on-secondary-fixed-variant": "#595c5a",
                        "on-primary-fixed": "#26453c",
                        "secondary-dim": "#505452",
                        "surface-container-highest": "#dde3ea",
                        "surface-dim": "#d3dbe3",
                        "surface-bright": "#f9f9fc",
                        "on-secondary-container": "#4f5251",
                        "on-tertiary-container": "#506144",
                        "on-surface": on_surface,
                        "secondary-fixed": "#e1e3e0",
                        "on-background": "#2d3339",
                        "error": "#9f403d",
                        "surface-tint": "#45655b",
                        "tertiary-container": "#e6fad5",
                        "primary-fixed": "#c7eade",
                        "surface": bg_surface,
                        "surface-container-high": "#e4e8ee",
                        "primary-fixed-dim": "#b9dcd0",
                        "inverse-primary": "#d3f6e9",
                        "outline-variant": "#acb3b9",
                        "tertiary-fixed-dim": "#d8ecc7",
                        "primary-dim": "#39584f",
                        "on-surface-variant": on_surface_variant,
                        "outline": "#757b82",
                        "error-container": "#fe8983",
                        "on-tertiary-fixed-variant": "#5a6b4e",
                        "secondary-container": "#e1e3e0",
                        "background": "#f9f9fc",
                        "on-tertiary": "#ecffdb",
                        "inverse-surface": "#0c0e10",
                        "on-error": "#fff7f6",
                        "tertiary-fixed": "#e6fad5",
                        "on-primary": on_primary_color,
                        "surface-container-low": "#f2f3f7"
                    },
                    fontFamily: {
                        "headline": [font_headline, "sans-serif"],
                        "body": [font_body, "serif"],
                        "label": [font_headline, "sans-serif"]
                    },
                    borderRadius: {"DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "0.75rem"},
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            display: inline-block;
            line-height: 1;
            text-transform: none;
            letter-spacing: normal;
            word-wrap: normal;
            white-space: nowrap;
            direction: ltr;
        }
        .editorial-quote-line {
            border-left: 2px solid var(--primary-color, #45655b);
            padding-left: 1rem;
        }
        .glass-header {
            background-color: rgba(249, 249, 252, 0.8);
            backdrop-filter: blur(20px);
        }
        body {
            font-smooth: antialiased;
            -webkit-font-smoothing: antialiased;
        }
        {Themusk::opt('custom_css')|noescape}
    </style>
    {Themusk::getTypoCSS()|noescape}
    <style type="text/tailwindcss">
        /* GeniXCMS Comments Layout */
        .comments-wrapper { @apply mt-8; }
        h3.fw-bold { @apply font-headline text-2xl font-black uppercase tracking-widest mb-6 border-b border-outline-variant/10 pb-4; }
        .comments-wrapper form .row { @apply flex flex-wrap -mx-3 gap-y-6; }
        .comments-wrapper .col-md-6 { @apply w-full md:w-1/2 px-3; }
        .comments-wrapper .col-md-12 { @apply w-full px-3; }
        .form-group label { @apply block text-xs font-label uppercase tracking-widest text-on-surface mb-2 font-bold; }
        .form-control { @apply w-full px-4 py-3 bg-surface-container-highest border border-outline-variant/30 rounded-lg text-on-surface focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all; }
        .form-control.editor { min-height: 120px; }
        .btn-success { @apply bg-primary text-on-primary px-8 py-3 rounded-md font-label text-[13px] uppercase tracking-widest font-semibold hover:opacity-90 hover:-translate-y-0.5 transition-all shadow-sm; border:none; cursor:pointer;}
        .input-help { @apply text-xs text-on-surface-variant block mt-2 opacity-70; }
        .alert { @apply p-4 mb-6 rounded-md text-sm font-label; }
        .alert-success { @apply bg-primary-container text-on-primary-container; }
        .alert-danger { @apply bg-error-container text-on-error-container; }
        
        .comments .row { @apply flex flex-col gap-6; }
        .d-flex { @apply flex gap-5; }
        .flex-shrink-0 { @apply shrink-0; }
        .flex-grow-1 { @apply grow w-full border border-outline-variant/20 rounded-xl p-6 bg-surface shadow-sm; }
        .img-thumbnail { @apply w-12 h-12 rounded-full object-cover ring-2 ring-primary/20; }
        .text-bg-primary { @apply text-primary bg-primary/10 text-[10px] px-3 py-1.5 rounded-full mt-3 inline-block uppercase tracking-widest font-bold text-center w-full; text-decoration:none; }
        .float-end { @apply float-right; }
        .meta-desc { @apply text-[10px] !text-on-surface-variant uppercase tracking-widest block mt-1 font-normal; }
        .flex-grow-1 h4 { @apply text-lg font-headline font-bold mb-3 text-on-surface; }
        .flex-grow-1 hr { @apply hidden; }
        #cancelreply .label-danger { @apply text-error bg-error/10 text-[10px] px-3 py-1.5 rounded-full uppercase tracking-widest font-bold inline-block; text-decoration:none; }
        .page-item.active .page-link { @apply bg-primary text-white border-primary; }
        .page-link { @apply text-primary bg-surface border border-outline-variant/30 px-3 py-1.5 rounded text-sm; }
        .pagination { @apply flex space-x-2 justify-center mt-6; list-style:none; padding:0; }
        .swiper-wrapper, .swiper-slide { height: auto !important; }
    </style>
    {Themusk::getLayoutCSS()|noescape}
    {$site_meta|noescape}
</head>
<body x-data="{ searchOpen: false, menuOpen: false }" :class="{ 'overflow-hidden': searchOpen || menuOpen }" class="bg-surface text-on-surface font-body selection:bg-primary-container selection:text-on-primary-container">
<!-- TopNavBar -->
<nav class="fixed top-0 w-full z-50 bg-white/80 dark:bg-zinc-950/80 backdrop-blur-md border-b border-zinc-100/10 dark:border-zinc-800/10">
    <div class="flex justify-between items-center h-20 px-site max-site-w">
        <div class="text-2xl font-bold tracking-tighter text-emerald-900 dark:text-emerald-50 shrink-0">
            <a href="{Site::$url}">
                {Site::logo('', '40px')|noescape}
            </a>
        </div>

        <div class="flex items-center space-x-8 ml-auto">
            <!-- Desktop Menu -->
            <div class="hidden md:flex items-center space-x-8">
                {var $menus = Menus::getMenuRaw('mainmenu')}
                {if is_array($menus) && !isset($menus['error'])}
                    {foreach $menus as $menu}
                        {var $type = $menu->type}
                        <a class="text-zinc-500 dark:text-zinc-400 hover:text-emerald-800 dark:hover:text-emerald-200 transition-colors font-medium" href="{Url::$type($menu->value)}">{$menu->name}</a>
                    {/foreach}
                {/if}
            </div>

            <!-- Desktop Search Button -->
            <div class="hidden md:flex items-center border-l border-zinc-200/50 pl-8 ml-8">
                <button @click="searchOpen = true" class="p-2 text-zinc-600 dark:text-zinc-400 hover:text-primary transition-colors duration-300">
                    <span class="material-symbols-outlined text-2xl" style="font-variation-settings: 'FILL' 0, 'wght' 500;">search</span>
                </button>
            </div>

            <!-- Mobile Menu Toggle -->
            <div class="flex md:hidden items-center">
                <button @click="menuOpen = !menuOpen" class="p-2 text-zinc-600 dark:text-zinc-400 hover:text-primary transition-colors">
                    <span class="material-symbols-outlined text-3xl" x-text="menuOpen ? 'close' : 'menu'">menu</span>
                </button>
            </div>
        </div>
    </div>
</nav>

<!-- Mobile Menu Drawer -->
<div x-show="menuOpen" 
     x-transition:enter="transition ease-out duration-300"
     x-transition:enter-start="translate-x-full"
     x-transition:enter-end="translate-x-0"
     x-transition:leave="transition ease-in duration-200"
     x-transition:leave-start="translate-x-0"
     x-transition:leave-end="translate-x-full"
     class="fixed inset-0 z-[55] bg-white dark:bg-zinc-950 md:hidden flex flex-col"
     style="display: none;">
    <div class="h-20 border-b border-zinc-100 dark:border-zinc-800 flex items-center justify-between px-site">
        <div class="text-2xl font-bold tracking-tighter text-emerald-900 dark:text-emerald-50">
            {Site::$name}
        </div>
        <button @click="menuOpen = false" class="p-2 text-zinc-600 dark:text-zinc-400">
            <span class="material-symbols-outlined text-3xl">close</span>
        </button>
    </div>
    <div class="flex-grow overflow-y-auto px-site py-12 flex flex-col justify-between">
        <div class="space-y-6">
            {var $mobileMenus = Menus::getMenuRaw('mainmenu')}
            {if is_array($mobileMenus) && !isset($mobileMenus['error'])}
                {foreach $mobileMenus as $menu}
                    {var $type = $menu->type}
                    <a href="{Url::$type($menu->value)}" class="block text-4xl font-headline font-black text-on-surface hover:text-primary transition-colors tracking-tighter uppercase" @click="menuOpen = false">{$menu->name}</a>
                {/foreach}
            {/if}
        </div>

        <div class="pt-12 border-t border-zinc-100 dark:border-zinc-800 mt-12">
            <button @click="menuOpen = false; searchOpen = true" class="w-full flex items-center justify-center space-x-4 bg-zinc-100 dark:bg-zinc-900 py-6 rounded-2xl text-on-surface-variant font-bold uppercase tracking-widest text-sm hover:bg-primary/10 hover:text-primary transition-all">
                <span class="material-symbols-outlined">search</span>
                <span>Search the Essays</span>
            </button>
        </div>
    </div>
</div>

<!-- Search Overlay -->
<div x-show="searchOpen" 
     x-transition:enter="transition ease-out duration-300"
     x-transition:enter-start="opacity-0 scale-95"
     x-transition:enter-end="opacity-100 scale-100"
     x-transition:leave="transition ease-in duration-200"
     x-transition:leave-start="opacity-100 scale-100"
     x-transition:leave-end="opacity-0 scale-95"
     class="fixed inset-0 z-[60] bg-white/95 dark:bg-zinc-950/95 backdrop-blur-xl flex flex-col items-center justify-center p-6"
     @keydown.escape.window="searchOpen = false"
     style="display: none;">
    
    <button @click="searchOpen = false" class="absolute top-8 right-8 p-4 text-zinc-400 hover:text-error transition-colors">
        <span class="material-symbols-outlined text-4xl">close</span>
    </button>

    <div class="w-full max-w-2xl text-center">
        <h2 class="font-label text-xs uppercase tracking-widest text-zinc-400 mb-8 font-bold">Search Articles</h2>
        <form action="{Site::$url}" method="get" class="relative group">
            <input type="text" name="search" placeholder="Enter keywords..." 
                   class="w-full bg-transparent border-b-2 border-zinc-200 dark:border-zinc-800 py-4 px-2 text-xl md:text-2xl font-body focus:outline-none focus:border-primary transition-colors placeholder:text-zinc-300 dark:placeholder:text-zinc-700"
                   x-init="$watch('searchOpen', value => value && setTimeout(() => $el.focus(), 100))">
            <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 p-2 text-zinc-400 hover:text-primary transition-colors">
                <span class="material-symbols-outlined text-2xl md:text-3xl">search</span>
            </button>
        </form>
    </div>
</div>

<main class="pt-32 pb-20 px-site max-site-w">
