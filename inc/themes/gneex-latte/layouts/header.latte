<!DOCTYPE html>
{var $is_home = ($p_type ?? '') == 'index' && (!isset($curr_paging) || $curr_paging == 1)}
<html lang="{$website_lang ?? 'en'}">
<head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    {$site_meta|noescape}

    <!-- HTML5 shim and Respond.js IE8 support of HTML5 elements and media queries -->
    <!--[if lt IE 9]>
      <script src="https://oss.maxcdn.com/html5shiv/3.7.2/html5shiv.min.js"></script>
      <script src="https://oss.maxcdn.com/respond/1.4.2/respond.min.js"></script>
      <![endif]-->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    </head>

    <body class="{(Gneex::opt('front_layout') == 'fullwidth' && $is_home) ? 'is-fullwidth' : ''}">
        <div id="fb-root"></div>

        {if (Gneex::opt('front_layout') != 'fullwidth' || !$is_home)}
        <header id="header" class="clearfix">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-6 col-md-2 logo">
                    <a class="" href="{$site_url}">
                        {Site::logo(Gneex::opt('logo_width'), Gneex::opt('logo_height'))|noescape}
                    </a>
                </div>
                <div class="col-6 col-md-10">
                    <nav class="navbar navbar-expand-lg py-3 py-lg-0" role="navigation">
                        <button type="button" class="navbar-toggler ms-auto border-0 shadow-none" data-bs-toggle="collapse" data-bs-target="#navbar-collapse-header">
                            <i class="fa fa-bars fs-3 text-dark"></i>
                        </button>
   
                        <div class="collapse navbar-collapse" id="navbar-collapse-header">
                            {Menus::getMenu('mainmenu', 'nav navbar-nav ms-auto align-items-lg-center mb-0', true)|noescape}
                            <div class="ms-lg-4 d-flex align-items-center h-100">
                                <form action="{$site_url}" method="get" class="search-form position-relative w-100 mt-3 mt-lg-0">
                                    <input type="text" name="q" class="form-control bg-light border-0 px-4 py-2" placeholder="Search..." style="width: 220px; border-radius: 50px;">
                                    <button type="submit" class="position-absolute end-0 top-50 translate-middle-y border-0 bg-transparent pe-3 text-muted">
                                        <i class="fa fa-search"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </nav>
                </div>
            </div>
        </div>
    </header>
    {/if}

    {var $opt = Gneex::$opt}
    {if ($p_type ?? '') == 'index' && Gneex::opt('front_layout') != 'fullwidth'}
    <section id="hero" class="hero-section">
        <div class="hero-bg" style="background-image: url({$opt['background_header']|noescape});">
            <div class="hero-overlay"></div>
            <div class="container hero-content">
                <div class="row align-items-center">
                    <div class="col-lg-7" data-aos="fade-right" data-aos-duration="1000">
                        <div class="hero-text-box">
                            <span class="badge bg-primary px-3 py-2 mb-3 fw-bold">FEATURED STORIES</span>
                            <h1 class="display-3 fw-extrabold mb-4" style="letter-spacing: -0.04em;">{$opt['intro_title']|nl2br|noescape}</h1>
                            <div class="hero-description lead mb-5">
                                {$opt['intro_text']|nl2br|noescape}
                            </div>
                            <div class="hero-actions">
                                {if !empty($opt['hero_btn_primary_link'])}
                                    {var $primaryBtnText = !empty($opt['hero_btn_primary_text']) ? $opt['hero_btn_primary_text'] : 'Start Reading'}
                                    <a href="{$opt['hero_btn_primary_link']}" class="btn btn-primary btn-lg px-5 me-3 shadow-lg border-0">{$primaryBtnText}</a>
                                {/if}
                                {if !empty($opt['hero_btn_secondary_link'])}
                                    {var $secondaryBtnText = !empty($opt['hero_btn_secondary_text']) ? $opt['hero_btn_secondary_text'] : 'Our Story'}
                                    <a href="{$opt['hero_btn_secondary_link']}" class="btn btn-glass btn-lg px-5" style="color: inherit !important;">{$secondaryBtnText}</a>
                                {/if}
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-5 d-none d-lg-block" data-aos="zoom-in" data-aos-delay="200">
                        <div class="hero-media-wrapper shadow-2xl overflow-hidden border border-white border-opacity-20">
                            {Gneex::introIg($opt['intro_image'])|noescape}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    {elseif ($p_type ?? '') != 'index'}
    <section id="inner-hero" class="inner-hero">
        <div class="hero-bg hero-bg-small" style="background-image: url({$opt['background_header']|noescape});">
            <div class="hero-overlay"></div>
            <div class="container hero-content text-center text-white" data-aos="fade-up">
                <h1 class="display-4 fw-bold pt-5 inner-hero-title">{$title ?? 'Blog'}</h1>
                <div class="breadcrumb-wrapper d-inline-block mt-4">
                    {Url::breadcrumbs([
                        'p_type' => ($p_type ?? ''),
                        'posts' => ($posts ?? []),
                        'cat' => ($cat ?? '')
                    ])|noescape}
                </div>
            </div>
        </div>
    </section>
    {/if}

