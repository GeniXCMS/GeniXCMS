<!DOCTYPE html>
<html lang="{$website_lang}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{$data['sitetitle'] ?? $site_name}</title>
    <meta name="description" content="{$data['p_desc'] ?? ''}">
    {$site_meta|noescape}
    {Site::loadLibHeader()|noescape}
    <style>
        body { background-color: #f8f9fa; font-family: 'Inter', system-ui, -apple-system, sans-serif; }
        .navbar { background: rgba(255,255,255,0.9); backdrop-filter: blur(10px); }
        .hero-section { padding: 80px 0; background: linear-gradient(135deg,#667eea 0%,#764ba2 100%); color: white; margin-bottom: 50px; }
        .fw-black { font-weight: 900; }
    </style>
</head>
<body class="layout-{$layout}">
    <nav class="navbar navbar-expand-lg border-bottom sticky-top shadow-sm mb-0">
        <div class="container">
            <!-- Brand -->
            <a class="navbar-brand fw-black text-primary d-flex align-items-center gap-2" href="{$site_url}">
                {if !empty($site_logo)}
                    {$site_logo|noescape}
                {else}
                    <i class="bi bi-layers-half fs-5"></i> {$site_name}
                {/if}
            </a>

            <!-- Toggler -->
            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#layoutTestNav" aria-controls="layoutTestNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Menu -->
            <div class="collapse navbar-collapse" id="layoutTestNav">
                <div class="ms-auto d-flex align-items-center gap-3">
                    {Menus::getMenu('mainmenu', 'navbar-nav gap-2 mb-2 mb-lg-0 small fw-bold', true)|noescape}

                    <!-- Search -->
                    <form class="d-flex" action="{$site_url}search" method="get">
                        <div class="input-group input-group-sm">
                            <input type="text" name="q" class="form-control rounded-pill px-3 border-0 bg-light" placeholder="Search..." style="width:160px;">
                            <button type="submit" class="btn btn-link text-muted px-2">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </nav>

    <main class="flex-grow-1" style="min-height: 60vh;">
        <div class="container mb-5">
