<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            {foreach $data['posts'] as $p}
                <article class="card border-0 shadow-sm rounded-4 p-5 mb-5">
                    <h1 class="fw-bold mb-3">{$p->title}</h1>
                    <div class="text-muted small mb-4">
                        <i class="bi bi-calendar3 me-1"></i> {Date::format($p->date)}
                        &bull;
                        <i class="bi bi-person me-1"></i>
                        <a href="{Url::author($p->author)}" class="text-dark text-decoration-none">{$p->author}</a>
                        {if $p->cat}
                            &bull;
                            <i class="bi bi-folder me-1"></i>
                            <a href="{Url::cat($p->cat)}" class="text-dark text-decoration-none">{Categories::name($p->cat)}</a>
                        {/if}
                    </div>

                    {var $post_image = Posts::getPostImage($p->id)}
                    {if !empty($post_image)}
                        <div class="mb-4 rounded-4 overflow-hidden">
                            <img src="{Url::thumb($post_image, 'large', 850)}" class="img-fluid w-100" alt="{$p->title}" loading="lazy">
                        </div>
                    {/if}

                    <div class="post-content fs-5 lh-lg">
                        {$content|noescape}
                    </div>
                </article>
            {/foreach}

            {if isset($data['comment_form'])}
                <div class="mt-4">
                    {$data['comment_form']|noescape}
                </div>
            {/if}
        </div>
    </div>
</div>
