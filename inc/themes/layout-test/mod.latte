{var $modName = $mod ?? ($data['mod'] ?? '')}
{var $mProps = Mod::getProperties($modName)}
{var $mod_layout = $mProps['layout'] ?? 'default'}
{var $show_title = $mProps['show_title'] ?? true}

<div class="min-vh-60">
    {if $mod_layout === 'fullwidth' || $mod_layout === 'full'}
        <!-- Full Width Layout (Bootstrap) -->
        {if $show_title}
            <header class="py-5 mb-5 text-center bg-white border-bottom">
                <div class="container">
                    <h1 class="display-4 fw-black mb-0">{Mod::getTitle($modName)|noescape}</h1>
                </div>
            </header>
        {/if}
        
        <div class="py-5 layout-test-module-content">
            {Hooks::run('mod_control', $data)|noescape}
        </div>
    {else}
        <!-- Default Container Layout (Bootstrap) -->
        <div class="container py-5">
            {if $show_title}
                <div class="row justify-content-center mb-5">
                    <div class="col-lg-10 text-center">
                        <h1 class="display-5 fw-black mb-3">{Mod::getTitle($modName)|noescape}</h1>
                        <hr class="w-25 mx-auto border-primary border-3 opacity-100 rounded">
                    </div>
                </div>
            {/if}

            <div class="row justify-content-center">
                <div class="col-lg-10">
                    <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white">
                        <div class="layout-test-module-content fs-6">
                            {Hooks::run('mod_control', $data)|noescape}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {/if}
</div>
