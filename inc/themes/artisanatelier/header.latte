<!DOCTYPE html>
<html class="light" lang="{$website_lang ?? substr(Options::v('system_lang'), 0, 2)}">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    {$site_meta|noescape}

    {Site::loadLibHeader()|noescape}
    
    <!-- Dynamic Config -->
    <script id="tailwind-config">
        {var $primary = ArtisanAtelier::opt('primary_color')}
        {var $secondary = ArtisanAtelier::opt('secondary_color')}
        {var $surface = ArtisanAtelier::opt('surface_color')}
        {var $on_surface = ArtisanAtelier::opt('on_surface_color')}
        
        tailwind.config = {
            darkMode: "class",
            theme: {
              extend: {
                "colors": {
                        "on-primary-container": "#721f0f",
                        "inverse-on-surface": "#9f9c99",
                        "surface": {$surface},
                        "surface-container-lowest": "#ffffff",
                        "on-tertiary-fixed": "#463600",
                        "on-surface-variant": "#66645e",
                        "surface-container-low": "#fdf9f4",
                        "on-primary-fixed": "#540900",
                        "secondary-container": "#d8fbc7",
                        "primary": {$primary},
                        "error": "#b3374e",
                        "secondary-fixed-dim": "#caecb9",
                        "tertiary-container": "#fdd34d",
                        "on-tertiary-container": "#5c4900",
                        "background": "#fffbff",
                        "inverse-primary": "#fa846c",
                        "surface-dim": "#e6e2d8",
                        "on-secondary-fixed-variant": "#4f6c43",
                        "error-container": "#f76a80",
                        "tertiary": "#7a6100",
                        "on-tertiary-fixed-variant": "#675200",
                        "on-secondary-container": "#45623a",
                        "surface-bright": "#fffbff",
                        "on-error-container": "#68001f",
                        "primary-fixed": "#ffac9b",
                        "primary-dim": "#973a27",
                        "surface-container-highest": "#ebe8df",
                        "on-background": "#393832",
                        "primary-container": "#ffac9b",
                        "error-dim": "#770326",
                        "tertiary-fixed-dim": "#eec540",
                        "surface-container": "#f7f3ed",
                        "on-surface": {$on_surface},
                        "tertiary-fixed": "#fdd34d",
                        "primary-fixed-dim": "#ff9782",
                        "on-secondary-fixed": "#334f29",
                        "inverse-surface": "#0f0e0c",
                        "secondary-dim": "#436038",
                        "secondary": {$secondary},
                        "on-error": "#ffffff",
                        "surface-container-high": "#f1ede6",
                        "on-secondary": "#ffffff",
                        "surface-tint": "#a74632",
                        "tertiary-dim": "#6c5600",
                        "on-primary-fixed-variant": "#7e2817",
                        "on-tertiary": "#ffffff",
                        "on-primary": "#ffffff",
                        "secondary-fixed": "#d8fbc7",
                        "outline-variant": "#bcb9b1",
                        "outline": "#828079",
                        "surface-variant": "#ebe8df"
                },
                "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "1.5rem",
                        "full": "9999px"
                },
                "fontFamily": {
                        "headline": ["Noto Serif"],
                        "body": ["Plus Jakarta Sans"],
                        "label": ["Plus Jakarta Sans"]
                }
              },
            },
          }
    </script>
    
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: {$surface|noescape}; color: {$on_surface|noescape}; }
        .text-primary { color: {$primary|noescape}; }
        .bg-primary { background-color: {$primary|noescape}; }
        .border-primary { border-color: {$primary|noescape}; }
    </style>
    
    {ArtisanAtelier::loadCustomCSS()|noescape}
</head>
<body class="bg-surface text-on-surface selection:bg-primary-container selection:text-on-primary-container">

<!-- TopNavBar -->
<nav class="bg-white/80 dark:bg-stone-900/80 backdrop-blur-xl docked full-width top-0 sticky z-50 shadow-[0_32px_32px_-4px_rgba(57,56,50,0.06)]">
    <div class="flex justify-between items-center w-full px-12 py-6 max-w-screen-2xl mx-auto">
        <div class="text-2xl font-serif font-bold text-orange-800 dark:text-orange-300 tracking-tighter">
            <a href="{$site_url}">{Site::$name}</a>
        </div>
        {Menus::getMenu('mainmenu', 'hidden md:flex gap-8 items-center m-0 p-0 list-none', false, 'text-stone-500 font-medium px-2 py-1 font-serif tracking-wide hover:text-orange-600 transition-colors duration-300')|noescape}
        <div class="flex items-center gap-6 text-stone-800 dark:text-stone-100">
            <a href="{Url::mod('cart')}" class="scale-95 active:transition-transform hover:text-orange-600 transition-colors nix-cart-container">
                <span class="material-symbols-outlined">shopping_bag</span>
                {Hooks::run('nix_cart_badge')|noescape}
            </a>
            <button class="scale-95 active:transition-transform hover:text-orange-600 transition-colors">
                <span class="material-symbols-outlined">favorite</span>
            </button>
            {if User::isLoggedin()}
                {var $u_name = Session::val('username')}
                <div class="relative group py-2">
                    <button class="scale-95 active:transition-transform hover:text-orange-600 transition-colors flex items-center" aria-label="{_('User Menu')}">
                        <span class="material-symbols-outlined">person</span>
                    </button>
                    <div class="absolute right-0 top-full pt-2 w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-[200] transform origin-top-right scale-95 group-hover:scale-100">
                        <div class="bg-white dark:bg-stone-800 border border-stone-100 dark:border-stone-700 rounded-xl shadow-2xl py-3 flex flex-col font-body text-sm font-semibold text-stone-800 dark:text-stone-200 overflow-hidden">
                            <div class="px-5 py-3 border-b border-stone-50 dark:border-stone-700 mb-1 bg-stone-50/50 dark:bg-stone-700/30">
                                <div class="text-[10px] text-stone-400 dark:text-stone-500 font-bold uppercase tracking-widest mb-0.5">{_('Signed in as')}</div>
                                <div class="truncate text-orange-800 dark:text-orange-400 font-bold">@{htmlspecialchars($u_name)}</div>
                            </div>
                            {var $dropdownItems = UserProfile::getDropdownItems()}
                            {foreach $dropdownItems as $key => $item}
                                {if isset($item['divider']) && $item['divider']}
                                    <hr class="my-1 border-stone-50 dark:border-stone-700">
                                {else}
                                    <a href="{$item['url']|noescape}" class="px-5 py-2.5 {if isset($item['danger']) && $item['danger']}text-red-500 hover:bg-red-50 dark:hover:bg-red-900/10{else}hover:bg-orange-50 dark:hover:bg-orange-900/10 hover:text-orange-800 dark:hover:text-orange-400{/if} transition-colors flex items-center gap-3">
                                        <span class="material-symbols-outlined !text-[20px] opacity-70">{$item['icon'] ?? 'chevron_right'}</span> 
                                        <span>{_($item['label'])}</span>
                                    </a>
                                {/if}
                            {/foreach}
                        </div>
                    </div>
                </div>
            {else}
                <a href="{Url::login()}" class="scale-95 active:transition-transform hover:text-orange-600 transition-colors">
                    <span class="material-symbols-outlined">person</span>
                </a>
            {/if}
        </div>
    </div>
</nav>
