{var $o = Bakeshop::options()}

<!-- Hero Section -->
<section class="px-8 max-w-7xl mx-auto py-16 md:py-24 animate-in fade-in duration-700">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
        <div class="md:col-span-7 space-y-6">
            <h2 class="text-primary font-headline text-xl font-bold uppercase tracking-widest">{$o['about_hero_subtitle']}</h2>
            <h1 class="text-on-surface font-headline text-5xl md:text-7xl font-extrabold tracking-tighter leading-none">
                {$o['about_hero_title']|noescape}
            </h1>
            <p class="text-on-surface-variant text-lg md:text-xl max-w-xl leading-relaxed">
                {$o['about_hero_desc']}
            </p>
        </div>
        <div class="md:col-span-5 relative">
            <div class="aspect-[4/5] rounded-lg overflow-hidden bg-surface-container shadow-xl">
                <img alt="Artisan cake" class="w-full h-full object-cover" src="{$o['about_hero_img']}"/>
            </div>
            <div class="absolute -bottom-6 -left-6 bg-secondary-container p-8 rounded-lg shadow-lg max-w-[200px]">
                <p class="text-on-secondary-container font-headline font-bold text-3xl">{$o['about_badge_num']}</p>
                <p class="text-on-secondary-container text-sm font-medium">{$o['about_badge_text']}</p>
            </div>
        </div>
    </div>
</section>

<!-- Brand Philosophy: Bento Grid -->
<section class="bg-surface-container-low py-24 px-8">
    <div class="max-w-7xl mx-auto">
        <div class="mb-16 text-center max-w-2xl mx-auto">
            <h2 class="text-on-surface font-headline text-4xl font-extrabold mb-4">{$o['about_phil_title']}</h2>
            <p class="text-on-surface-variant">{$o['about_phil_desc']}</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <!-- Bento Item 1 -->
            <div class="md:col-span-2 bg-surface-container-lowest p-10 rounded-lg shadow-sm border border-outline-variant/10 flex flex-col justify-between">
                <div class="space-y-4">
                    <span class="material-symbols-outlined text-primary text-4xl" style="font-variation-settings: 'FILL' 1;">palette</span>
                    <h3 class="text-2xl font-headline font-bold">Intentional Artistry</h3>
                    <p class="text-on-surface-variant leading-relaxed">Every swirl of frosting and placement of a delicate leaf is done with artistic intent. We don't just bake; we curate an experience that begins with the eyes.</p>
                </div>
                <div class="mt-8 flex gap-2">
                    <span class="px-4 py-1 bg-tertiary-container text-on-tertiary-container rounded-full text-[10px] font-bold uppercase tracking-wider">Visual Poetry</span>
                    <span class="px-4 py-1 bg-secondary-container text-on-secondary-container rounded-full text-[10px] font-bold uppercase tracking-wider">Aesthetic Focus</span>
                </div>
            </div>
            <!-- Bento Item 2 -->
            <div class="bg-primary-container p-10 rounded-lg text-on-primary-container flex flex-col justify-center">
                <span class="material-symbols-outlined text-5xl mb-4">temp_preferences_custom</span>
                <h3 class="text-2xl font-headline font-bold mb-4">Small Batches</h3>
                <p class="opacity-90">Precision is our secret ingredient. By working in micro-batches, we ensure the perfect crumb and moisture in every single bite.</p>
            </div>
            <!-- Bento Item 3 -->
            <div class="bg-secondary p-10 rounded-lg text-on-secondary flex flex-col justify-between">
                <h3 class="text-2xl font-headline font-bold text-on-secondary">Pure Ingredients</h3>
                <p class="opacity-80">Grass-fed butter, single-origin chocolate, and seasonal fruits from local growers. Quality is never compromised.</p>
                <div class="mt-4 flex items-center gap-2">
                    <div class="w-3 h-3 bg-secondary-container rounded-full animate-pulse"></div>
                    <span class="text-sm font-medium">Freshly Sourced Today</span>
                </div>
            </div>
            <!-- Bento Item 4 -->
            <div class="md:col-span-2 bg-surface-container-lowest p-10 rounded-lg shadow-sm border border-outline-variant/10 flex flex-col md:flex-row gap-8 items-center">
                <div class="flex-1 space-y-4">
                    <h3 class="text-2xl font-headline font-bold">Community Rooted</h3>
                    <p class="text-on-surface-variant">The Gallery is more than a store; it’s a gathering place. We support local artists by displaying their work alongside our seasonal collections.</p>
                </div>
                <div class="w-full md:w-48 aspect-square rounded-lg overflow-hidden bg-surface-container">
                    <img alt="Bakery Interior" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAqy-sOz0fLd8cGm4sbY1Dfi_bAvPGO_1sQPuAhxxwWaltqJZO5mrlwjJWRcVJc4S2m8E9l6trS77pR4xjWbjSv5q8okcRQoZhPGxWiUlnz_h5qIdKG_kHRi9HejT_LpSgfCr_3YY4hqw26wVFoBaXsgKxGbLZXDEunFfS5hP_6arg9qCIv14FmDPh-mFILQKsJ5REeVOyX_AE4Gzf_233kewdUoBX2kJbPZGFYOQcIikM49G7b87b519wuU-fSHNF93zTFZgKbons"/>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Mission Statement: Layered Depth -->
<section class="py-24 relative overflow-hidden text-center">
    <div class="absolute top-0 left-0 w-full h-full bg-primary/5 -skew-y-3 origin-top-left -z-10"></div>
    <div class="max-w-4xl mx-auto px-8 space-y-8">
        <div class="inline-block p-4 rounded-full bg-surface-container-lowest shadow-lg mb-4">
            <span class="material-symbols-outlined text-primary text-5xl">auto_awesome</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-headline font-extrabold text-on-surface tracking-tight leading-tight">
            "{$o['about_mission']|noescape}"
        </h2>
        <div class="h-1 w-24 bg-primary mx-auto rounded-full"></div>
    </div>
</section>

<!-- Team Section -->
<section class="py-24 px-8 max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-4">
        <div class="max-w-xl">
            <h2 class="text-primary font-headline text-xl font-bold uppercase tracking-widest mb-2">{$o['about_team_title']}</h2>
            <h3 class="text-4xl font-headline font-extrabold">{$o['about_team_subtitle']}</h3>
        </div>
        <p class="text-on-surface-variant max-w-sm">{$o['about_team_desc']}</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Baker 1 -->
        <div class="group">
            <div class="aspect-[3/4] rounded-lg overflow-hidden bg-surface-container-high mb-6 relative">
                <img class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500" src="{$o['team1_img']}"/>
                <div class="absolute inset-0 bg-primary/20 opacity-0 group-hover:opacity-100 transition-opacity"></div>
            </div>
            <h4 class="text-xl font-headline font-bold">{$o['team1_name']}</h4>
            <p class="text-primary font-medium text-sm mb-2">{$o['team1_role']}</p>
            <p class="text-on-surface-variant text-sm">{$o['team1_bio']}</p>
        </div>
        <!-- Baker 2 -->
        <div class="group">
            <div class="aspect-[3/4] rounded-lg overflow-hidden bg-surface-container-high mb-6 relative">
                <img class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500" src="{$o['team2_img']}"/>
                <div class="absolute inset-0 bg-secondary/20 opacity-0 group-hover:opacity-100 transition-opacity"></div>
            </div>
            <h4 class="text-xl font-headline font-bold">{$o['team2_name']}</h4>
            <p class="text-secondary font-medium text-sm mb-2">{$o['team2_role']}</p>
            <p class="text-on-surface-variant text-sm">{$o['team2_bio']}</p>
        </div>
        <!-- Baker 3 -->
        <div class="group">
            <div class="aspect-[3/4] rounded-lg overflow-hidden bg-surface-container-high mb-6 relative">
                <img class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500" src="{$o['team3_img']}"/>
                <div class="absolute inset-0 bg-tertiary/20 opacity-0 group-hover:opacity-100 transition-opacity"></div>
            </div>
            <h4 class="text-xl font-headline font-bold">{$o['team3_name']}</h4>
            <p class="text-tertiary font-medium text-sm mb-2">{$o['team3_role']}</p>
            <p class="text-on-surface-variant text-sm">{$o['team3_bio']}</p>
        </div>
        <!-- Baker 4 -->
        <div class="group">
            <div class="aspect-[3/4] rounded-lg overflow-hidden bg-surface-container-high mb-6 relative">
                <img class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500" src="{$o['team4_img']}"/>
                <div class="absolute inset-0 bg-primary-container/20 opacity-0 group-hover:opacity-100 transition-opacity"></div>
            </div>
            <h4 class="text-xl font-headline font-bold">{$o['team4_name']}</h4>
            <p class="text-on-primary-container font-medium text-sm mb-2">{$o['team4_role']}</p>
            <p class="text-on-surface-variant text-sm">{$o['team4_bio']}</p>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="py-24 px-8">
    <div class="max-w-5xl mx-auto bg-surface-container-highest rounded-xl p-12 md:p-20 text-center relative overflow-hidden">
        <div class="relative z-10 space-y-8">
            <h2 class="text-4xl md:text-5xl font-headline font-extrabold text-on-surface tracking-tight">Ready to taste the dream?</h2>
            <p class="text-on-surface-variant text-lg max-w-xl mx-auto">Visit us in the heart of the district or order a custom creation for your next milestone.</p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <button class="bg-gradient-to-r from-primary to-primary-container text-on-primary px-8 py-4 rounded-full font-bold text-lg shadow-lg hover:shadow-primary/20 transition-all active:scale-95">
                    Browse the Collection
                </button>
                <button class="border border-outline-variant/30 text-primary px-8 py-4 rounded-full font-bold text-lg hover:bg-surface-container-high transition-all active:scale-95">
                    Our Locations
                </button>
            </div>
        </div>
        <!-- Decorative element -->
        <div class="absolute -top-24 -right-24 w-64 h-64 bg-primary-container/10 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-secondary-container/20 rounded-full blur-3xl"></div>
    </div>
</section>
