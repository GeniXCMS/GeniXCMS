<!DOCTYPE html>
<html lang="en">
<head>
    {$site_meta|noescape}
    
    {Site::loadLibHeader()|noescape}
    <!-- Bootstrap Core CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Custom CSS -->
    <link href="{$theme_url}/css/clean-blog.css" rel="stylesheet">
    <!-- Custom Fonts -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" type="text/css">
    <link href='https://fonts.googleapis.com/css?family=Lora:400,700,400italic,700italic' rel='stylesheet' type='text/css'>
    <link href='https://fonts.googleapis.com/css?family=Open+Sans:300italic,400italic,600italic,700italic,800italic,400,300,600,700,800' rel='stylesheet' type='text/css'>

    <style>
        /* Modern BS5 Adjustments for Clean Blog */
        .navbar-custom { background: transparent; border: none; padding-top: 20px; padding-bottom: 20px; transition: all 0.3s; }
        .navbar-custom .navbar-brand { font-weight: 800; color: #fff; }
        .navbar-custom .nav-link { font-weight: 800; color: #fff; text-transform: uppercase; font-size: 12px; letter-spacing: 1px; }
        .navbar-custom .nav-link:hover { color: rgba(255,255,255,0.8); }
        .intro-header { margin-bottom: 50px; background: no-repeat center center; background-attachment: scroll; background-size: cover; padding: 150px 0; color: #fff; text-align: center; }
        .intro-header .site-heading h1 { font-size: 80px; font-weight: 800; }
        .intro-header .subheading { font-size: 24px; font-weight: 300; display: block; margin: 10px 0 0; font-family: 'Open Sans',sans-serif; }
        .post-preview > a { color: #212529; text-decoration: none; }
        .post-preview > a:hover { color: #0085A1; }
        .post-preview .post-title { font-size: 30px; margin-top: 30px; margin-bottom: 10px; font-weight: 800; }
        .post-preview .post-subtitle { font-weight: 300; margin-bottom: 10px; color: #6c757d; }
        .post-meta { font-size: 18px; font-style: italic; margin-top: 0; color: #6c757d; }
        footer { padding: 50px 0 65px; border-top: 1px solid #dee2e6; }
        .btn-primary { background-color: #0085A1; border-color: #0085A1; padding: 10px 20px; border-radius: 0; font-weight: 800; }
        .btn-primary:hover { background-color: #00697d; }
    </style>
</head>

<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark navbar-custom fixed-top" id="mainNav">
        <div class="container container-fluid px-4 px-lg-5">
            <a class="navbar-brand" href="{$site_url}">{$site_name}</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarResponsive" aria-controls="navbarResponsive" aria-expanded="false" aria-label="Toggle navigation">
                Menu <i class="fas fa-bars"></i>
            </button>
            <div class="collapse navbar-collapse" id="navbarResponsive">
                {Menus::getMenu('mainmenu', 'navbar-nav ms-auto py-4 py-lg-0', true)|noescape}
            </div>
        </div>
    </nav>
